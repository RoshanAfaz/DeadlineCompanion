{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/_server/:path*",
      "destination": "https://deadlinecompanion.onrender.com/_server/:path*"
    },
    {
      "source": "/_/:path*",
      "destination": "https://deadlinecompanion.onrender.com/_/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "https://deadlinecompanion.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
